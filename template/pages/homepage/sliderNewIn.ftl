<a class="category-banner-link" href="<@ofbizCatalogAltUrl productCategoryId="NEWIN"/>">
    <div class="category-banner">

        <picture>
            <!-- mobile -->
            <source media="(max-width: 768px)" srcset="<@ofbizContentUrl>${assetspath}/images/homepage/mobile/newIn_slider_mob.jpg</@ofbizContentUrl>">

            <!-- tablet -->
            <source media="(max-width: 1200px)" srcset="<@ofbizContentUrl>${assetspath}/images/homepage/newIn_slider_desk.jpg</@ofbizContentUrl>">

            <!-- fallback desktop -->
            <img src="<@ofbizContentUrl>${assetspath}/images/homepage/newIn_slider_desk.jpg</@ofbizContentUrl>" class="banner-img" alt="Top">
        </picture>

        <div class="banner-caption">
            <h2 class="banner-title font-sz-xlarge text-uppercase text-white" data-animate="fadeInUp">${SystemLabelMap.NewIn}</h2>
        </div>

    </div>
</a>