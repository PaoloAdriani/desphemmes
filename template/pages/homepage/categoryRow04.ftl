                <!-- mobile -->
                <source media="(max-width: 768px)" srcset="<@ofbizContentUrl>${assetspath}/images/homepage/mobile/knitwear024_mob.jpg</@ofbizContentUrl>">

                <!-- tablet -->
                <source media="(max-width: 1200px)" srcset="<@ofbizContentUrl>${assetspath}/images/homepage/knitwear024_desk.jpg</@ofbizContentUrl>">

                <!-- fallback desktop -->
